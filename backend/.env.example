PORT=8000
JWT_SECRET=replace-with-a-long-random-jwt-secret
AES_SECRET=replace-with-a-long-random-aes-secret
MONGO_URI=mongodb://127.0.0.1:27017/medtara

# Set to true only for isolated demos or offline testing.
# ALLOW_FILE_DB=true

# Optional HTTPS mode
# HTTPS_ENABLED=true
# SSL_KEY_PATH=C:\path\to\localhost-key.pem
# SSL_CERT_PATH=C:\path\to\localhost-cert.pem

# AI Service (Python Flask on port 5001)
AI_SERVICE_URL=http://localhost:5001
# The Gemini API key is configured in ai-services/.env
# Get your key at: https://aistudio.google.com/app/apikey
